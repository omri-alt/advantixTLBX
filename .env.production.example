# KLblend production .env — copy to .env on the server and fill secrets.
# Do not commit .env. See docker-compose.yml (runtime/ + data/ volumes) and secrets/credentials.json.

# --- AutoServer scheduler (hourly automations on /automations) ---
AUTOSERVER_SCHEDULER_ENABLED=1
# Hour gates for even/odd jobs (QualityWL, KLWL, BlendSync2h, KeitaroFeedBalanceCheckmon).
AUTOSERVER_SCHEDULER_TZ=Europe/Jerusalem
# Optional: run all hourly jobs once after deploy (off by default; can overload worker).
# AUTOSERVER_STARTUP_CATCHUP=0

# --- SourceKnowledge (QualityWL, KLWL, SKExplorationOptimizer, optimizers) ---
KEYSK=
# Legacy alias also accepted: keySK=

# --- Zeropark (Mehilot, CloseNipuhim) ---
KEYZP=

# --- Ecomnia (MehilotAuto track sheets) — KLblend names or legacy AutoServer names ---
ADVERTISER_KEY=
AUTH_KEY=
SECRET_KEY=
# Legacy: ECadvKey, ECauthKey, ECsecretKey (set via ensure_autoserver_env if above are set)

# --- Kelkoo / daily workflow ---
# FEED1_API_KEY= ...
# KEITARO_BASE_URL=
# KEITARO_API_KEY=

# --- Blend + Keitaro automations ---
# BLEND_SHEETS_SPREADSHEET_ID=
TRILLION_BLEND_CAP_GUARD_ENABLED=1
KEITARO_FEED_BALANCE_CHECKMON_ENABLED=yes

# --- Google Sheets (service account file mounted at /app/credentials.json in Docker) ---
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json
SK_TOOLS_SPREADSHEET_ID=
# SK_OPTIMIZER_SHEET_ID=  # defaults to SK_TOOLS_SPREADSHEET_ID

# --- Flask ---
# FLASK_SECRET_KEY=
